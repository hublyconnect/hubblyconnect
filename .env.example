# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key

# Meta / Facebook API
FACEBOOK_APP_ID=
NEXT_PUBLIC_FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
NEXT_PUBLIC_FB_REDIRECT_URI=http://localhost:3000/api/auth/facebook/callback

# WhatsApp Webhook (verificação Meta)
WHATSAPP_VERIFY_TOKEN=seu_token_secreto

# WhatsApp API (opcional - tokens podem vir do metadata do cliente)
WHATSAPP_ACCESS_TOKEN=

# Cron (webhook interno)
CRON_SECRET=

# Google Calendar API
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary

# Portal do Cliente - WhatsApp da agência
NEXT_PUBLIC_AGENCY_WHATSAPP=

# Asaas - Financeiro
ASAAS_API_KEY=
ASAAS_API_URL=https://api.asaas.com/v3

# Senha inicial para novos clientes/membros (produção)
DEFAULT_CLIENT_PASSWORD=
